#!/bin/sh
# =============================================================================
# Maven Wrapper Script
# =============================================================================
set -e

MAVEN_PROJECTBASEDIR=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd -P)
MAVEN_WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"

# Read distribution URL
DISTRIBUTION_URL=$(grep 'distributionUrl' "$MAVEN_WRAPPER_PROPERTIES" | sed 's/distributionUrl=//')

# Derive local install dir
MAVEN_VERSION=$(echo "$DISTRIBUTION_URL" | sed 's/.*apache-maven-\([0-9.]*\)-.*/\1/')
MAVEN_HOME="$HOME/.m2/wrapper/dists/apache-maven-${MAVEN_VERSION}-bin/apache-maven-${MAVEN_VERSION}"

# Download Maven if not present
if [ ! -f "$MAVEN_HOME/bin/mvn" ]; then
    echo "Downloading Apache Maven ${MAVEN_VERSION}..."
    mkdir -p "$HOME/.m2/wrapper/dists"
    TMPFILE=$(mktemp /tmp/maven-XXXXXX.zip)
    if command -v curl > /dev/null 2>&1; then
        curl -fsSL -o "$TMPFILE" "$DISTRIBUTION_URL"
    elif command -v wget > /dev/null 2>&1; then
        wget -q -O "$TMPFILE" "$DISTRIBUTION_URL"
    else
        echo "ERROR: Neither curl nor wget found. Please install Maven manually."
        exit 1
    fi
    mkdir -p "$HOME/.m2/wrapper/dists"
    unzip -q "$TMPFILE" -d "$HOME/.m2/wrapper/dists"
    rm -f "$TMPFILE"
    echo "Maven ${MAVEN_VERSION} downloaded successfully."
fi

exec "$MAVEN_HOME/bin/mvn" "$@"
